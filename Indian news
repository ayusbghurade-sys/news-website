                    <a href="#" class="flex items-center space-x-2">
                        <div class="bg-rose-600 text-white p-1 rounded font-black text-xl px-3 italic">GN</div>
                        <span class="text-2xl font-black text-gray-900 tracking-tighter uppercase hidden sm:block">Global<span class="text-rose-600">News</span></span>
                    </a>
                </div>

                <!-- Desktop Nav -->
                <nav class="hidden lg:flex space-x-6 text-sm font-bold uppercase tracking-wide text-gray-700">
                    <a href="#" class="hover:text-rose-600 transition-colors">Home</a>
                    <a href="#" class="hover:text-rose-600 transition-colors">Politics</a>
                    <a href="#" class="hover:text-rose-600 transition-colors">Cricket</a>
                    <a href="#" class="hover:text-rose-600 transition-colors">Entertainment</a>
                    <a href="#" class="hover:text-rose-600 transition-colors">Business</a>
                    <a href="#" class="hover:text-rose-600 transition-colors">Tech</a>
                    <a href="#" class="hover:text-rose-600 transition-colors">World</a>
                </nav>

                <!-- Search & Login -->
                <div class="flex items-center space-x-4">
                    <button class="text-gray-500 hover:text-rose-600">
                        <i class="fa-solid fa-magnifying-glass text-lg"></i>
                    </button>
                    <button class="bg-rose-600 text-white px-4 py-2 rounded-md font-bold text-sm hover:bg-rose-700 transition-all hidden md:block">
                        LOGIN
                    </button>
                    <button class="lg:hidden text-gray-700" id="mobile-menu-btn">
                        <i class="fa-solid fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Breaking News Ticker -->
    <div class="bg-gray-900 text-white py-2 overflow-hidden flex items-center">
        <div class="bg-rose-600 px-4 py-1 font-black text-sm uppercase z-10 relative shadow-lg italic">Breaking</div>
        <div class="news-ticker-container flex-1">
